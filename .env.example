# HubSpot Forms API v3 configuratie voor de ESG Quickscan Light lead-flow.
# Kopieer dit bestand naar .env.local en vul de waarden in.
# .env.local is al ge-gitignored en wordt nooit gecommit.

# Portal ID van je HubSpot-account (8 cijfers).
# Te vinden in HubSpot: Settings > Account Setup > Account Defaults.
VITE_HUBSPOT_PORTAL_ID=

# Form GUID van het "ESG Quickscan Light"-form dat je in HubSpot hebt
# aangemaakt. Te vinden in de embed-code van het form (UUID).
VITE_HUBSPOT_FORM_GUID=

# Subscription Type ID voor "ESG-updates Act Right" (optioneel — als je
# geen aparte subscription hebt, laat leeg en de marketing-opt-in wordt
# niet meegestuurd).
# Te vinden via Settings > Marketing > Email > Subscription Types.
VITE_HUBSPOT_SUBSCRIPTION_ID=
